{
  "name": "etiquetas-prom-web",
  "version": "1.0.0",
  "description": "Expert Administração - gestão de artigos, campanhas e etiquetas com Supabase.",
  "keywords": [],
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "@zxing/browser": "^0.1.5",
    "@zxing/library": "^0.21.3",
    "dotenv": "^16.6.1",
    "jsbarcode": "3.12.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^6.22.3",
    "react-scripts": "^5.0.0",
    "tesseract.js": "^7.0.0",
    "xlsx": "0.18.5"
  },
  "devDependencies": {
    "@types/react": "19.0.0",
    "@types/react-dom": "19.0.0",
    "loader-utils": "3.2.1",
    "typescript": "^4.9.5"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test --env=jsdom",
    "eject": "react-scripts eject",
    "test:ci": "react-scripts test --watch=false --runInBand",
    "qa:static": "python3 scripts/qa_check.py",
    "seed:articles": "node scripts/import-artigos-to-supabase.mjs",
    "validate:artigos-json": "node -e \"const fs=require('fs');const data=JSON.parse(fs.readFileSync('src/data/artigos.json','utf8'));if(!Array.isArray(data.artigos)){throw new Error('artigos.json precisa de conter um array artigos')}console.log('artigos.json válido:', data.artigos.length, 'artigos')\"",
    "repair:artigos-json": "node scripts/repair-artigos-json.mjs",
    "migrate:article-prices": "node scripts/migrate-artigos-prices-to-supabase.mjs",
    "qa:saas": "python3 scripts/saas_readiness_check.py",
    "qa:all": "npm run qa:static && npm run qa:saas && npm --prefix server run smoke",
    "migrate:articles-db-update": "node scripts/migrate-artigos-db-update-to-supabase.mjs"
  },
  "browserslist": [
    ">0.2%",
    "not dead",
    "not ie <= 11",
    "not op_mini all"
  ],
  "private": true
}
