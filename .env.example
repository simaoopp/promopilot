# -----------------------------------------------------------------------------
# Frontend / Supabase
# -----------------------------------------------------------------------------
REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_PUBLISHABLE_KEY=
REACT_APP_SUPABASE_ANON_KEY=
REACT_APP_API_BASE_URL=https://etiquetasprom.onrender.com

# -----------------------------------------------------------------------------
# Backend / Supabase
# ATENÇÃO: SUPABASE_SERVICE_ROLE_KEY deve ficar apenas em ambiente backend seguro
# que precise mesmo de service_role, preferencialmente Cloud Run/Secret Manager.
# Não colocar esta chave no Netlify/frontend nem no Render normal da API pública.
# -----------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ARTICLES_TABLE=articles

GEMINI_API_KEY=
CORS_ORIGINS=https://expertadmin.netlify.app
ALLOW_LOCALHOST_CORS=0
ADMIN_EMAILS=admin@example.com
API_RATE_LIMIT_WINDOW_MS=900000
API_RATE_LIMIT_MAX=600
ADMIN_RATE_LIMIT_WINDOW_MS=900000
ADMIN_RATE_LIMIT_MAX=60
JSON_BODY_LIMIT=2mb
PORT=3001

# -----------------------------------------------------------------------------
# Campanhas automáticas por email
# Configuração segura por defeito: Render/backend não corre worker pesado.
# Cloud Run Job recebe as envs próprias através de cloudbuild.yaml/Secret Manager
# -----------------------------------------------------------------------------
CAMPAIGN_EMAIL_WORKER_ENABLED=0
CAMPAIGN_EMAIL_WORKER_RUN_ON_START=0
CAMPAIGN_EMAIL_WORKER_INTERVAL_MS=300000
CAMPAIGN_EMAIL_SEND_ENABLED=0

# Em testes fica 0 para não marcar emails como lidos automaticamente.
# Depois de validares em produção, podes mudar para 1.
CAMPAIGN_EMAIL_MARK_SEEN=1

CAMPAIGN_DEFAULT_TITLE=PROMOÇÃO
CAMPAIGN_TITLE_FROM_EMAIL=0
CAMPAIGN_DEDUPE_ENABLED=1
CAMPAIGN_DEDUPE_BY_SUBJECT=1
CAMPAIGN_REPROCESS_ERRORED=1
CAMPAIGN_DEFAULT_FORMAT=automatico
AUTOMATIC_CAMPAIGN_HISTORY_DAYS=5
AUTOMATIC_CAMPAIGN_CLEANUP_ENABLED=1
AUTOMATIC_CAMPAIGN_CLEANUP_DAYS=5
AUTOMATIC_CAMPAIGN_CLEANUP_BATCH_SIZE=100
AUTOMATIC_CAMPAIGN_BUCKET=automatic-campaign-pdfs
CAMPAIGN_STORE_RAW_EMAIL=0

# -----------------------------------------------------------------------------
# IMAP - caixa que recebe os emails de campanha
# Conta configurada para receber campanhas: etiquetasprom@gmail.com
# Para Gmail, usar App Password; a password normal da conta normalmente não funciona.
# -----------------------------------------------------------------------------
CAMPAIGN_IMAP_HOST=imap.gmail.com
CAMPAIGN_IMAP_PORT=993
CAMPAIGN_IMAP_SECURE=1
CAMPAIGN_IMAP_USER=etiquetasprom@gmail.com
CAMPAIGN_IMAP_PASS=COLOCAR_APP_PASSWORD_DO_GMAIL
CAMPAIGN_IMAP_MAILBOX=INBOX
CAMPAIGN_IMAP_MAILBOXES=INBOX
CAMPAIGN_IMAP_AUTO_DISCOVER_MAILBOXES=0
CAMPAIGN_EMAIL_DEBUG=0
CAMPAIGN_EMAIL_FROM=
CAMPAIGN_EMAIL_SUBJECT_INCLUDES=Resumo
CAMPAIGN_EMAIL_UNSEEN_ONLY=1
CAMPAIGN_EMAIL_SEEN_ONLY=0
CAMPAIGN_EMAIL_MAX_MESSAGES=2
CAMPAIGN_EMAIL_SCAN_LIMIT=20

# -----------------------------------------------------------------------------
# Envio dos PDFs por API HTTPS - recomendado no Render
# Resend usa HTTPS/443 e evita o bloqueio das portas SMTP em planos gratuitos.
# 1) Criar API key no Resend
# 2) Usar onboarding@resend.dev para testes ou validar domínio para produção
# -----------------------------------------------------------------------------
CAMPAIGN_EMAIL_PROVIDER=resend
RESEND_API_KEY=COLOCAR_RESEND_API_KEY
CAMPAIGN_EMAIL_FROM_ADDRESS=Etiquetas Promo <onboarding@resend.dev>
CAMPAIGN_EMAIL_REPLY_TO=etiquetasprom@gmail.com
CAMPAIGN_EMAIL_API_TIMEOUT_MS=30000
CAMPAIGN_EMAIL_API_DEBUG=0

# -----------------------------------------------------------------------------
# SMTP - opcional/legado. Deixar vazio no Render Free.
# Só usar se o serviço permitir portas SMTP 465/587.
# -----------------------------------------------------------------------------
CAMPAIGN_SMTP_HOST=
CAMPAIGN_SMTP_PORT=465
CAMPAIGN_SMTP_SECURE=1
CAMPAIGN_SMTP_REQUIRE_TLS=1
CAMPAIGN_SMTP_USER=
CAMPAIGN_SMTP_PASS=
CAMPAIGN_SMTP_FROM=
CAMPAIGN_SMTP_CONNECTION_TIMEOUT_MS=30000
CAMPAIGN_SMTP_GREETING_TIMEOUT_MS=30000
CAMPAIGN_SMTP_SOCKET_TIMEOUT_MS=60000
CAMPAIGN_SMTP_FALLBACK_ENABLED=1
CAMPAIGN_SMTP_FALLBACKS=465:ssl,587:starttls
CAMPAIGN_SMTP_DEBUG=0

# -----------------------------------------------------------------------------
# Destinatários das lojas - MODO TESTE
# Todos recebem no teu email de teste.
# Para produção, substituir pelos emails reais das lojas.
# -----------------------------------------------------------------------------
CAMPAIGN_STORE_EMAIL_PRAIA=simaopereira308@gmail.com
CAMPAIGN_STORE_EMAIL_ANGRA=simaopereira308@gmail.com
CAMPAIGN_STORE_EMAIL_VALADOS=simaopereira308@gmail.com


# Catálogo grande/Supabase: nunca pedir mais do que 1000 linhas por página.
ARTICLES_CACHE_PAGE_SIZE=1000
ARTICLES_CACHE_CONCURRENCY=2
ARTICLES_SUPABASE_MAX_ROWS=1000
WARM_ARTICLES_CACHE=0
