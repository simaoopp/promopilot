# -----------------------------------------------------------------------------
# Frontend / Supabase
# -----------------------------------------------------------------------------
REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_PUBLISHABLE_KEY=
REACT_APP_SUPABASE_ANON_KEY=
REACT_APP_API_BASE_URL=https://etiquetasprom.onrender.com

# -----------------------------------------------------------------------------
# Backend / Supabase
# ATENÇÃO: SUPABASE_SERVICE_ROLE_KEY deve ficar apenas no backend/Render.
# Nunca colocar esta chave no Netlify/frontend.
# -----------------------------------------------------------------------------
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ARTICLES_TABLE=articles

GEMINI_API_KEY=
CORS_ORIGINS=https://expertadmin.netlify.app,http://localhost:3000,http://localhost:8888
PORT=3001

# -----------------------------------------------------------------------------
# Campanhas automáticas por email
# Configuração deixada ON para testes.
# Durante os testes, todos os PDFs vão para: simaopereira308@gmail.com
# -----------------------------------------------------------------------------
CAMPAIGN_EMAIL_WORKER_ENABLED=1
CAMPAIGN_EMAIL_WORKER_RUN_ON_START=1
CAMPAIGN_EMAIL_WORKER_INTERVAL_MS=30000
CAMPAIGN_EMAIL_SEND_ENABLED=1

# Em testes fica 0 para não marcar emails como lidos automaticamente.
# Depois de validares em produção, podes mudar para 1.
CAMPAIGN_EMAIL_MARK_SEEN=1

CAMPAIGN_DEFAULT_TITLE=PROMOÇÃO
CAMPAIGN_TITLE_FROM_EMAIL=0
CAMPAIGN_DEDUPE_ENABLED=1
CAMPAIGN_DEDUPE_BY_SUBJECT=1
CAMPAIGN_REPROCESS_ERRORED=0
CAMPAIGN_DEFAULT_FORMAT=automatico
AUTOMATIC_CAMPAIGN_HISTORY_DAYS=30
AUTOMATIC_CAMPAIGN_BUCKET=automatic-campaign-pdfs

# -----------------------------------------------------------------------------
# IMAP - caixa que recebe os emails de campanha
# Conta configurada para receber campanhas: etiquetasprom@gmail.com
# Para Gmail, usar App Password; a password normal da conta normalmente não funciona.
# -----------------------------------------------------------------------------
CAMPAIGN_IMAP_HOST=imap.gmail.com
CAMPAIGN_IMAP_PORT=993
CAMPAIGN_IMAP_SECURE=1
CAMPAIGN_IMAP_USER=etiquetasprom@gmail.com
CAMPAIGN_IMAP_PASS=COLOCAR_APP_PASSWORD_DO_GMAIL
CAMPAIGN_IMAP_MAILBOX=INBOX
CAMPAIGN_IMAP_MAILBOXES=INBOX,[Gmail]/All Mail
CAMPAIGN_IMAP_AUTO_DISCOVER_MAILBOXES=1
CAMPAIGN_EMAIL_DEBUG=1
CAMPAIGN_EMAIL_FROM=
CAMPAIGN_EMAIL_SUBJECT_INCLUDES=Resumo Alterações_PV2
CAMPAIGN_EMAIL_UNSEEN_ONLY=1
CAMPAIGN_EMAIL_SEEN_ONLY=0
CAMPAIGN_EMAIL_MAX_MESSAGES=10

# -----------------------------------------------------------------------------
# SMTP - envio dos PDFs
# Para Gmail, usar a mesma App Password da conta etiquetasprom@gmail.com.
# -----------------------------------------------------------------------------
CAMPAIGN_SMTP_HOST=smtp.gmail.com
CAMPAIGN_SMTP_PORT=465
CAMPAIGN_SMTP_SECURE=1
CAMPAIGN_SMTP_REQUIRE_TLS=1
CAMPAIGN_SMTP_USER=etiquetasprom@gmail.com
CAMPAIGN_SMTP_PASS=COLOCAR_APP_PASSWORD_DO_GMAIL
CAMPAIGN_SMTP_FROM=etiquetasprom@gmail.com
CAMPAIGN_SMTP_CONNECTION_TIMEOUT_MS=30000
CAMPAIGN_SMTP_GREETING_TIMEOUT_MS=30000
CAMPAIGN_SMTP_SOCKET_TIMEOUT_MS=60000
CAMPAIGN_SMTP_FALLBACK_ENABLED=1
CAMPAIGN_SMTP_FALLBACKS=465:ssl,587:starttls
CAMPAIGN_SMTP_DEBUG=1

# -----------------------------------------------------------------------------
# Destinatários das lojas - MODO TESTE
# Todos recebem no teu email de teste.
# Para produção, substituir pelos emails reais das lojas.
# -----------------------------------------------------------------------------
CAMPAIGN_STORE_EMAIL_PRAIA=simaopereira308@gmail.com
CAMPAIGN_STORE_EMAIL_ANGRA=simaopereira308@gmail.com
CAMPAIGN_STORE_EMAIL_VALADOS=simaopereira308@gmail.com

# Debug IMAP: quantos emails recentes analisar por mailbox
CAMPAIGN_EMAIL_SCAN_LIMIT=100
