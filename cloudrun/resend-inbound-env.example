# Cloud Run Service: Resend Inbound Webhook
# Serviço HTTP público, protegido por assinatura Svix/Resend.
NODE_ENV=production
WARM_ARTICLES_CACHE=0

CAMPAIGN_RESEND_INBOUND_ENABLED=1
RESEND_WEBHOOK_SECRET=<secret do webhook Resend/Svix>

SUPABASE_URL=<secret>
SUPABASE_PUBLISHABLE_KEY=<secret>
SUPABASE_SERVICE_ROLE_KEY=<secret>

RESEND_API_KEY=<secret>
CAMPAIGN_EMAIL_PROVIDER=resend
CAMPAIGN_EMAIL_SEND_ENABLED=1
CAMPAIGN_EMAIL_FROM_ADDRESS=Etiquetas Promo <onboarding@resend.dev>
CAMPAIGN_EMAIL_REPLY_TO=<email-de-resposta>

CAMPAIGN_DEFAULT_ORGANIZATION_ID=<uuid-da-organization>
CAMPAIGN_DEFAULT_FORMAT=automatico
CAMPAIGN_DEFAULT_TITLE=PROMOÇÃO
CAMPAIGN_PDF_ENGINE=playwright
CAMPAIGN_PDF_ALLOW_APPROX_FALLBACK=0

AUTOMATIC_CAMPAIGN_BUCKET=automatic-campaign-pdfs
AUTOMATIC_CAMPAIGN_HISTORY_DAYS=5
AUTOMATIC_CAMPAIGN_CLEANUP_ENABLED=1
AUTOMATIC_CAMPAIGN_CLEANUP_DAYS=5

CAMPAIGN_DEDUPE_ENABLED=1
CAMPAIGN_DEDUPE_BY_SUBJECT=1
CAMPAIGN_REPROCESS_ERRORED=1

CAMPAIGN_STORE_EMAIL_ANGRA=<destino-angra>
CAMPAIGN_STORE_EMAIL_PRAIA=<destino-praia>
CAMPAIGN_STORE_EMAIL_VALADOS=<destino-valados>

CAMPAIGN_EMAIL_WORKER_ENABLED=0
CAMPAIGN_EMAIL_WORKER_RUN_ON_START=0
